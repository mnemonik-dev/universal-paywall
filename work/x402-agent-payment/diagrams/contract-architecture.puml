@startuml contract-architecture
title PaymentSplitter Contract — Architecture (EIP-3009 wrapper)

skinparam backgroundColor #FAFAFA
skinparam classBackgroundColor #E8F5E9
skinparam classBorderColor #4CAF50

class PaymentSplitter <<Ownable, Pausable, ReentrancyGuard>> {
  -- Storage --
  + owner: address
  + paused: bool
  + feeBps: uint16          // 0..1000, default 50
  + developers: mapping(address => Developer)
  + platformBalance: uint256
  + usdc: IERC20  (immutable)

  -- Developer Registry --
  + register(wallet: address): void         // idempotent, open
  + getBalance(developer: address): uint256

  -- Payment (settle entry point) --
  + payWithAuthorization(
      developerId: address,
      value: uint256,
      validAfter: uint256,
      validBefore: uint256,
      nonce: bytes32,
      v: uint8, r: bytes32, s: bytes32
    ): void
    // 1) Pausable: when not paused
    // 2) require developers[developerId].registered
    // 3) IERC3009(usdc).transferWithAuthorization(
    //      msg.sender? NO — `from` is recovered inside USDC from sig
    //      authorization.from, splitter, value, validAfter, validBefore, nonce, v, r, s
    //    )
    // 4) fee = value * feeBps / 10000
    // 5) developers[developerId].balance += value - fee
    // 6) platformBalance += fee
    // 7) emit PaymentReceived(developerId, from, value, fee)

  -- Withdrawal --
  + withdraw(amount: uint256): void          // nonReentrant, msg.sender-gated
  + withdrawAll(): void

  -- Admin --
  + setFee(bps: uint16): void               // owner-only, require bps <= 1000
  + withdrawPlatformFees(to: address): void  // owner-only
  + pause(): void                            // owner-only
  + unpause(): void                          // owner-only
}

class Developer <<struct>> {
  + registered: bool
  + balance: uint256
  + registeredAt: uint64
}

interface IERC3009 {
  + transferWithAuthorization(
      from, to, value, validAfter, validBefore, nonce, v, r, s
    )
  + authorizationState(from, nonce): bool
}

class "Middleware\n(off-chain facilitator)" as MW {
  + withPaywall(handler, config): Handler
  + fastifyPaywall(config): FastifyPlugin
  -- config --
  + price: string  ("0.01")
  + developerId: address
  + network: "arc-testnet" | "arc-mainnet"
  + facilitator: {
      mode: "inline",
      relayerKey: 0x...,
      rpcUrl?: string
    }
}

class "AI Agent\n(buyer)" as Agent {
  + Any x402 v1 client
    (CDP SDK / Circle SDK / hand-rolled)
  + Signs EIP-712 TransferWithAuthorization
    off-chain (no gas)
  + USDC balance on Arc Testnet
}

Agent ..> MW : 1) GET (no header)
MW ..> Agent : 2) 402 + JSON body\n   (PaymentRequirements)
Agent ..> MW : 3) GET + X-PAYMENT\n   (signed authorization)
MW ..> MW : 4) verify EIP-712 off-chain\n   check NonceStore (TTL)
MW --> PaymentSplitter : 5) payWithAuthorization(...)\n   (relayer pays gas in USDC)
PaymentSplitter --> IERC3009 : 6) transferWithAuthorization\n   (settles, sets authorizationState)
IERC3009 --> PaymentSplitter : USDC arrived
PaymentSplitter --> Developer : credit (value - fee)
MW ..> Agent : 7) 200 + X-PAYMENT-RESPONSE

note bottom of PaymentSplitter
  Deployed ONCE by platform on Arc Testnet.
  All developers share one contract.
  Platform fee changeable by owner only (≤10%).
  Pausable: blocks payments, allows withdrawals.
  Replay protection: USDC.authorizationState on-chain;
  middleware NonceStore at API level.
end note

@enduml
