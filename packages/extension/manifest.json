{
  "manifest_version": 3,
  "name": "Universal Paywall",
  "version": "0.0.1",
  "description": "Auto-pay x402 paywalls on the user's behalf and let other extensions request paid fetches via the Universal Paywall rail.",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "externally_connectable": {
    "ids": ["*"]
  }
}
