{
  "name": "@universal-paywall/integrations",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "e2e:anvil": "tsx scripts/e2e-integration-anvil.ts",
    "e2e:owncast": "tsx scripts/e2e-owncast-acceptance-anvil.ts",
    "e2e:mastodon": "node scripts/e2e-mastodon-donation-anvil.mjs"
  },
  "dependencies": {
    "@universal-paywall/sdk": "*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "bin": {
    "up-integration": "./dist/cli.js"
  }
}
