{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/coinbase/x402/specs/schemes/exact/scheme_exact_evm.md",
  "title": "x402 v1 wire format",
  "description": "Vendored x402 v1 JSON Schema covering PaymentRequirements, ExactEvmPayload, PaymentPayload, the 402 challenge body envelope, and the X-PAYMENT-RESPONSE shape. Transcribed from the x402 v1 spec (github.com/coinbase/x402/specs/schemes/exact/scheme_exact_evm.md) — see header for spec URL. Update header SHA when re-syncing.",
  "definitions": {
    "Address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "Bytes32": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{64}$"
    },
    "Signature": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{130}$"
    },
    "DecimalIntegerString": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "NetworkId": {
      "type": "string",
      "minLength": 1
    },
    "ExactEvmExtra": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetTransferMethod", "name", "version"],
      "properties": {
        "assetTransferMethod": { "const": "eip3009" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "PaymentRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scheme",
        "network",
        "maxAmountRequired",
        "resource",
        "description",
        "mimeType",
        "payTo",
        "maxTimeoutSeconds",
        "asset",
        "extra"
      ],
      "properties": {
        "scheme": { "const": "exact" },
        "network": { "$ref": "#/definitions/NetworkId" },
        "maxAmountRequired": { "$ref": "#/definitions/DecimalIntegerString" },
        "resource": { "type": "string" },
        "description": { "type": "string" },
        "mimeType": { "type": "string" },
        "payTo": { "$ref": "#/definitions/Address" },
        "maxTimeoutSeconds": { "type": "integer", "minimum": 0 },
        "asset": { "$ref": "#/definitions/Address" },
        "extra": { "$ref": "#/definitions/ExactEvmExtra" }
      }
    },
    "ExactEvmAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "value", "validAfter", "validBefore", "nonce"],
      "properties": {
        "from": { "$ref": "#/definitions/Address" },
        "to": { "$ref": "#/definitions/Address" },
        "value": { "$ref": "#/definitions/DecimalIntegerString" },
        "validAfter": { "$ref": "#/definitions/DecimalIntegerString" },
        "validBefore": { "$ref": "#/definitions/DecimalIntegerString" },
        "nonce": { "$ref": "#/definitions/Bytes32" }
      }
    },
    "ExactEvmPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signature", "authorization"],
      "properties": {
        "signature": { "$ref": "#/definitions/Signature" },
        "authorization": { "$ref": "#/definitions/ExactEvmAuthorization" }
      }
    },
    "PaymentPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x402Version", "scheme", "network", "payload"],
      "properties": {
        "x402Version": { "const": 1 },
        "scheme": { "const": "exact" },
        "network": { "$ref": "#/definitions/NetworkId" },
        "payload": { "$ref": "#/definitions/ExactEvmPayload" }
      }
    },
    "ChallengeBody": {
      "type": "object",
      "additionalProperties": true,
      "required": ["x402Version", "accepts"],
      "properties": {
        "x402Version": { "const": 1 },
        "accepts": {
          "type": "array",
          "items": { "$ref": "#/definitions/PaymentRequirements" }
        },
        "error": { "type": "string" },
        "reason": { "type": "string" },
        "settlementReason": { "type": "string" },
        "required": { "$ref": "#/definitions/DecimalIntegerString" },
        "received": { "$ref": "#/definitions/DecimalIntegerString" }
      }
    },
    "XPaymentResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "transaction", "network", "payer"],
      "properties": {
        "success": { "type": "boolean" },
        "transaction": { "$ref": "#/definitions/Bytes32" },
        "network": { "$ref": "#/definitions/NetworkId" },
        "payer": { "$ref": "#/definitions/Address" }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/ChallengeBody" },
    { "$ref": "#/definitions/PaymentPayload" },
    { "$ref": "#/definitions/XPaymentResponse" }
  ]
}
