# Real .env is gitignored. Copy to .env and fill values locally.

# JSON-RPC endpoint for Arc Network (testnet for MVP; mainnet later).
# Used by forge for the `arc_testnet` rpc endpoint and by post-deploy TS helpers.
ARC_RPC_URL=https://rpc.arc-testnet.example/

# Private key (0x-prefixed hex) for the deploy EOA. Used by `forge script ... --broadcast`.
# Replace with your own 0x-prefixed 64-hex-char private key locally; the
# all-zeros key is a publicly-known monitored address and must NOT be used.
DEPLOYER_KEY=0x<your-0x-prefixed-64-hex-char-private-key>

# API key for the Arc Network block explorer / verifier. Used by `forge script ... --verify`.
ARC_VERIFY_API_KEY=replace-me
