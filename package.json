{
  "private": true,
  "name": "universal-paywall",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "contracts"
  ],
  "scripts": {
    "lint": "eslint packages/middleware --ext .ts,.cts,.mts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
